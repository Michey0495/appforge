{
  "policies": {
    "standard": {
      "name": "標準ポリシー",
      "description": "一般的な社内システム向けのパスワードポリシー",
      "rules": {
        "min_length": 8,
        "max_length": 64,
        "require_uppercase": true,
        "require_lowercase": true,
        "require_numbers": true,
        "require_symbols": false,
        "disallow_dictionary_words": false,
        "disallow_sequential_chars": false,
        "disallow_repeated_chars": false,
        "max_repeated_chars": 3,
        "disallow_username_in_password": true
      },
      "rotation": {
        "enabled": true,
        "max_age_days": 180,
        "min_age_days": 1,
        "history_count": 5,
        "notify_before_expiry_days": 14
      },
      "lockout": {
        "max_failed_attempts": 10,
        "lockout_duration_minutes": 15,
        "reset_counter_after_minutes": 60
      }
    },
    "enterprise": {
      "name": "エンタープライズポリシー",
      "description": "機密情報を扱うシステム向けの強化ポリシー",
      "rules": {
        "min_length": 12,
        "max_length": 128,
        "require_uppercase": true,
        "require_lowercase": true,
        "require_numbers": true,
        "require_symbols": true,
        "min_symbol_count": 1,
        "allowed_symbols": "!@#$%^&*()-_=+[]{}|;:,.<>?",
        "disallow_dictionary_words": true,
        "dictionary_check_languages": ["ja", "en"],
        "disallow_sequential_chars": false,
        "disallow_repeated_chars": true,
        "max_repeated_chars": 2,
        "disallow_username_in_password": true,
        "disallow_email_in_password": true,
        "min_unique_chars": 8
      },
      "rotation": {
        "enabled": true,
        "max_age_days": 90,
        "min_age_days": 1,
        "history_count": 12,
        "notify_before_expiry_days": 14
      },
      "lockout": {
        "max_failed_attempts": 5,
        "lockout_duration_minutes": 30,
        "reset_counter_after_minutes": 30
      },
      "mfa_required": true
    },
    "critical": {
      "name": "最重要システムポリシー",
      "description": "金融・個人情報等の最高機密レベル向けポリシー",
      "rules": {
        "min_length": 16,
        "max_length": 128,
        "require_uppercase": true,
        "require_lowercase": true,
        "require_numbers": true,
        "require_symbols": true,
        "min_symbol_count": 2,
        "allowed_symbols": "!@#$%^&*()-_=+[]{}|;:,.<>?",
        "disallow_dictionary_words": true,
        "dictionary_check_languages": ["ja", "en"],
        "disallow_sequential_chars": true,
        "max_sequential_chars": 2,
        "disallow_repeated_chars": true,
        "max_repeated_chars": 1,
        "disallow_username_in_password": true,
        "disallow_email_in_password": true,
        "disallow_common_patterns": true,
        "common_patterns": ["qwerty", "asdf", "1234", "abcd", "password", "admin"],
        "min_unique_chars": 12,
        "entropy_minimum_bits": 60
      },
      "rotation": {
        "enabled": true,
        "max_age_days": 30,
        "min_age_days": 1,
        "history_count": 24,
        "notify_before_expiry_days": 7
      },
      "lockout": {
        "max_failed_attempts": 3,
        "lockout_duration_minutes": 60,
        "reset_counter_after_minutes": 15,
        "permanent_lockout_after": 10,
        "admin_unlock_required": true
      },
      "mfa_required": true,
      "hardware_key_required": true,
      "session_timeout_minutes": 15
    }
  },
  "global_settings": {
    "password_breach_check": true,
    "breach_check_api": "haveibeenpwned",
    "show_strength_meter": true,
    "generate_suggestions": true,
    "allow_passphrase": true,
    "passphrase_min_words": 5
  }
}
